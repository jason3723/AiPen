{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "AiPen",
  "version": "3.0.2",
  "identifier": "com.aipen.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/jason3723/AiPen/releases/latest/download/latest.json",
        "https://raw.githubusercontent.com/jason3723/AiPen/main/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU0NEMyRjY1NDc2QjE2QUMKUldTc0ZtdEhaUzlNVkkvclJzMjk3c1hZb1A0MnIwRHlrc09SNzUrSlZQcFFsWUxBQlNWejAyWE4K"
    }
  },
  "app": {
    "windows": [
      {
        "title": "AiPen — AI 辅助文档写作",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "center": true,
        "decorations": false,
        "devtools": false,
        "backgroundColor": "#2a2c3c"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPLOCALDATA/images/**/*"]
      }
    }
  }
}
